# Copy this file to .env and fill in your own private values.
# Never commit .env or real API keys.

UW_API_KEY=

# Discord listener bot
# Create this in the Discord Developer Portal, invite it to your private server,
# and enable Message Content Intent if needed.
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# Comma-separated channel IDs to read UW bot/custom-alert posts from.
DISCORD_LISTEN_CHANNEL_IDS=

# Channel ID where the Layer 8 summary bot should post summaries.
DISCORD_SUMMARY_CHANNEL_ID=

# Alert destinations
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Runtime
APP_ENV=local
DATABASE_URL=sqlite:///data/uw_signals.sqlite3
LOG_LEVEL=INFO
SUMMARY_INTERVAL_SECONDS=300

# Trading universe defaults
INDEX_SYMBOLS=SPX,SPY,QQQ,IWM
STOCK_SYMBOLS=TSLA,NVDA,AAPL,AMD,META,MSFT,AMZN
