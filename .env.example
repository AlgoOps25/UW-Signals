# Copy this file to .env and fill in your own private values.
# Never commit .env or real API keys.

UW_API_KEY=

# Alert destinations
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Runtime
APP_ENV=local
DATABASE_URL=sqlite:///data/uw_signals.sqlite3
LOG_LEVEL=INFO

# Trading universe defaults
INDEX_SYMBOLS=SPX,SPY,QQQ,IWM
STOCK_SYMBOLS=TSLA,NVDA,AAPL,AMD,META,MSFT,AMZN
